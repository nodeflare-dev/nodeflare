# ===========================================
# NPM Security Configuration
# ===========================================

# Disable lifecycle scripts (postinstall, preinstall, etc.)
# Prevents supply chain attacks via malicious install scripts
ignore-scripts=true

# Security audit settings
audit=true
audit-level=high

# Strict SSL/TLS
strict-ssl=true

# Use exact versions (no ^ or ~) when saving
save-exact=true

# Prevent accidental publish
private=true

# Registry (use official npm registry only)
registry=https://registry.npmjs.org/

# Require package-lock.json
package-lock=true

# Peer dependency handling (relaxed for CI compatibility)
# strict-peer-deps=true
legacy-peer-deps=false

# Engine strict mode
engine-strict=true

# ===========================================
# After `npm install`, run: npm run setup
# ===========================================
