# ===========================================
# MCP Cloud Configuration
# ===========================================

# Database - Neon PostgreSQL (https://neon.tech)
# Get your connection string from Neon dashboard
DATABASE_URL=postgres://user:password@ep-xxx.region.aws.neon.tech/mcp_cloud?sslmode=require

# Cache - Upstash Redis (https://upstash.com)
# Get your connection string from Upstash dashboard
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ===========================================
# Authentication
# ===========================================

# JWT Secret (generate with: openssl rand -base64 64)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Encryption Key for secrets (32 bytes, base64 encoded)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-32-byte-encryption-key-base64-encoded

# ===========================================
# GitHub OAuth App
# ===========================================
# Create at: https://github.com/settings/developers

GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/v1/auth/github/callback

# ===========================================
# GitHub App (for repo access)
# ===========================================
# Create at: https://github.com/settings/apps

GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...your private key here...
-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ===========================================
# Fly.io (Production deployment)
# ===========================================
# Get token from: https://fly.io/user/personal_access_tokens

FLY_API_TOKEN=your-fly-api-token
FLY_ORG=your-fly-org-name
FLY_REGION=nrt

# ===========================================
# Server Configuration
# ===========================================

# API Server
API_HOST=0.0.0.0
API_PORT=8080

# Proxy Gateway
PROXY_HOST=0.0.0.0
PROXY_PORT=8081

# Proxy Base Domain (for subdomain routing)
# Production: nodeflare.tech -> {slug}.nodeflare.tech
# Development: localhost:8081 -> {slug}.localhost:8081
PROXY_BASE_DOMAIN=nodeflare.tech

# --- Proxy tuning (all optional, sensible defaults shown) ---
# Max client request / upstream response body size in bytes (default 10MB).
# PROXY_BODY_LIMIT_BYTES=10485760
# Total upstream request timeout for non-streaming requests, seconds (default 30).
# PROXY_UPSTREAM_TIMEOUT_SECS=30
# Idle (read) timeout for SSE/streaming upstreams, seconds; no total timeout (default 120).
# PROXY_SSE_IDLE_TIMEOUT_SECS=120
# HTTP connection-pool idle timeout, seconds (default 90).
# PROXY_POOL_IDLE_TIMEOUT_SECS=90
# Request cache TTL / capacity / max cached response size.
# PROXY_CACHE_TTL_SECS=30
# PROXY_CACHE_MAX_ENTRIES=10000
# PROXY_CACHE_MAX_RESPONSE_SIZE=1048576

# --- Client IP / proxy trust (rate-limit & lockout correctness) ---
# Trust reverse-proxy headers (X-Forwarded-For, X-Real-IP, etc.). Off by default.
# TRUST_PROXY_HEADERS=false
# Number of trusted reverse-proxy hops in front of the proxy; the client IP is taken
# this many entries from the RIGHT of X-Forwarded-For (default 1). Never trust the
# spoofable leftmost entry.
# TRUSTED_PROXY_HOPS=1
# Set true only when actually deployed behind Fly's edge, so fly-client-ip is trusted.
# PROXY_BEHIND_FLY=false

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ===========================================
# Optional: External Services
# ===========================================

# Sentry (error tracking)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Axiom (logging)
# AXIOM_TOKEN=your-axiom-token
# AXIOM_DATASET=mcp-cloud

# ===========================================
# Stripe Billing
# ===========================================
# Get your keys from: https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App URL for Stripe redirects
APP_URL=http://localhost:3000

# Price IDs (create products in Stripe Dashboard or use MCP)
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_TEAM_MONTHLY=price_xxx
STRIPE_PRICE_TEAM_YEARLY=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_YEARLY=price_xxx

# Usage-based billing (GB-hours = memory x active hours), per-server, paid plans only.
# Modern Stripe requires metered prices to be backed by a Billing Meter. To ENABLE
# usage charging:
#   1. Create a Billing Meter with event_name = STRIPE_USAGE_METER_EVENT below,
#      default_aggregation.formula = sum, customer_mapping.type = by_id /
#      event_payload_key = stripe_customer_id, value_settings.event_payload_key = value.
#   2. Create a metered price on the Pro product backed by that meter, e.g. graduated
#      tiers: first 250 GB-hours at 0 (the Pro included allowance), then JPY 4/GB-hour.
#   3. Put the price id here. Leave empty to keep usage internal-only (measured + shown,
#      not billed).
STRIPE_PRICE_PRO_USAGE=
# The Billing Meter event_name usage is reported under. Must match the meter backing
# STRIPE_PRICE_PRO_USAGE. Defaults to nodeflare_gb_hours if unset.
STRIPE_USAGE_METER_EVENT=nodeflare_gb_hours
# Display-only estimate shown in the dashboard (JPY per GB-hour). Recommended ~4.
USAGE_RATE_JPY_PER_GB_HOUR=4
# How often to sample running machines (seconds). Billing resolution = this interval.
USAGE_SAMPLE_INTERVAL_SECS=300
# How often to report accumulated usage to Stripe (seconds).
USAGE_REPORT_INTERVAL_SECS=3600

# ===========================================
# Email (Resend)
# ===========================================
# Get your API key from: https://resend.com/api-keys

RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@nodeflare.tech
EMAIL_FROM_NAME=Nodeflare
